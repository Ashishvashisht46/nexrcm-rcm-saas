# ─── NexRCM Environment Configuration ───────────────────────
# Copy this to .env and fill in your values

# Server
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# Database (PostgreSQL)
DATABASE_URL=postgresql://nexrcm:nexrcm_password@localhost:5432/nexrcm?schema=public

# Redis (for job queues & caching)
REDIS_URL=redis://localhost:6379

# JWT Auth
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your-refresh-secret-change-this
JWT_REFRESH_EXPIRES_IN=7d

# Encryption (for SSN, sensitive fields)
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# File Storage (S3)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=nexrcm-files

# Stripe (Patient Payments)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Clearinghouse (EDI Integration)
CLEARINGHOUSE_API_URL=https://api.clearinghouse.com/v1
CLEARINGHOUSE_API_KEY=
CLEARINGHOUSE_SUBMITTER_ID=

# Email (SendGrid)
SENDGRID_API_KEY=SG....
EMAIL_FROM=noreply@nexrcm.com

# AI — OpenRouter (supports 100+ models at various price points)
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=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

# Choose your model (uncomment one):
# CHEAPEST:
AI_MODEL=deepseek/deepseek-chat-v3-0324
# AI_MODEL=google/gemini-2.0-flash-001
# AI_MODEL=meta-llama/llama-3.1-70b-instruct
# AI_MODEL=qwen/qwen-2.5-72b-instruct
# BEST QUALITY (more expensive):
# AI_MODEL=anthropic/claude-sonnet-4
# AI_MODEL=openai/gpt-4o
# AI_MODEL=anthropic/claude-3.5-haiku

# App URL (for OpenRouter tracking)
APP_URL=http://localhost:3000

# Session
SESSION_TIMEOUT_MINUTES=15

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=info
